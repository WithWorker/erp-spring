<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.backend.mapper.CalendarMapper">  
  <resultMap id="calendarResultMap" type="com.erp.backend.dto.CalendarDto">
      <result column="calendar_id" property="calendar_id"/>
      <result column="start_date" property="start_date"/>
      <result column="end_date" property="end_date"/>
      <result column="title" property="title"/>
      <result column="content" property="content"/>
      <result column="applicant_id" property="applicant_id"/>
  </resultMap>

  <select id="getAllCalendars" resultMap="calendarResultMap">
    SELECT calendar_id, start_date, end_date, title, content, applicant_id FROM calendar;
  </select>
</mapper>