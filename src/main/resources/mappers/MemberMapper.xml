<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.erp.backend.mapper.MemberMapper">

    <!-- 전체조회 -->
    <select id="findAll" resultMap="memberResult">
        SELECT * FROM employee
    </select>
    <resultMap id="memberResult" type="com.erp.backend.dto.MemberDto">
        <result property="empId" column="emp_id" />
        <result property="name" column="name" />
        <result property="email" column="email" />
        <result property="password" column="password" />
        <result property="phone" column="phone" />
        <result property="imgUrl" column="img_url" />
        <result property="dept" column="dept" />
        <result property="position" column="position" />
        <result property="memberRole" column="member_role" />
    </resultMap>

    <!--사원조회 (by 이름)-->
    <select id="findByName" parameterType="java.lang.String" resultType="com.erp.backend.dto.MemberDto">
        SELECT * FROM employee WHERE name = #{name}
    </select>

    <!--사원조회 (by 이메일)-->
    <select id="findByEmail" parameterType="java.lang.String" resultType="com.erp.backend.dto.MemberDto">
        SELECT * FROM employee WHERE email = #{email}
    </select>

    <!-- 사원등록 -->
    <insert id="insertMember" parameterType="com.erp.backend.dto.MemberDto">
        INSERT INTO employee (emp_id, name, email, password, phone, img_url, dept, position, member_role)
        VALUES (#{empId}, #{name}, #{email}, #{password}, #{phone}, #{imgUrl}, #{dept}, #{position}, #{memberRole})
    </insert>

    <!-- 사원수정 -->
    <update id="updateMember" parameterType="com.erp.backend.dto.MemberDto">
        UPDATE employee SET
                            name = #{name},
                            email = #{email},
                            phone = #{phone},
                            dept = #{dept},
                            position = #{position}
        WHERE emp_id = #{empId}
    </update>

    <!-- 사원삭제 -->
    <delete id="deleteMember" parameterType="java.lang.Long">
        DELETE FROM employee WHERE emp_id = #{empId}
    </delete>

</mapper>
